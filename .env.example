# ============================================
# LLM 配置（通用格式，兼容任何 OpenAI 协议的模型）
# ============================================
#
# 两种配置方式：
#   方式1：通用配置  → 只用一个模型，变量名用 LLM_ 开头
#   方式2：多模型配置 → 同时配多个模型，变量名用 PROVIDER_ 开头（如 DEEPSEEK_、OPENAI_）
#
# 代码里的用法：
#   LLMClient()                    → 读 LLM_ 开头的通用配置
#   LLMClient(provider="deepseek") → 读 DEEPSEEK_ 开头的配置
#   LLMClient(provider="openai")   → 读 OPENAI_ 开头的配置
#
# provider 命名规则：就是 .env 里的前缀转小写
#   DEEPSEEK_  → provider="deepseek"
#   OPENAI_    → provider="openai"
#   MOONSHOT_  → provider="moonshot"
#   自定义前缀也可以，如 MYMODEL_ → provider="mymodel"
#
# 也可以直接传参，不走 .env：
#   LLMClient(api_key="sk-xxx", base_url="https://...", model="...")
#
# ============================================

# 复制此文件为 .env 并填入你的真实配置

# ---- 方式1：通用配置（推荐，只用一个模型时用这个）----
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ---- 方式2：多模型配置（需要切换多个模型时取消注释）----
# LLM_DEFAULT_PROVIDER=deepseek

# DeepSeek
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Moonshot（月之暗面）
# MOONSHOT_API_KEY=your-moonshot-api-key
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=moonshot-v1-8k

# ==========================
# 嵌入（Embedding）配置示例 - 可从阿里云控制台获取：https://dashscope.aliyun.com/
# ==========================
# - 若为空，dashscope 默认 text-embedding-v3；local 默认 sentence-transformers/all-MiniLM-L6-v2
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=text-embedding-v4
EMBED_API_KEY=your-dashscope-api-key-here
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
